---
import { getEntry } from 'astro:content'

const settings = await getEntry('settings', 'global')
const currentYear = new Date().getFullYear()
const companyName = settings.data.company_name || 'Deep Roots Drainage'
const phone = settings.data.phone || '(701) 555-0123'
const email = settings.data.email || 'info@deeprootsdrainage.com'
const location = settings.data.location || 'North Dakota'
const description = settings.data.footer_description || ''
const ctaText = settings.data.footer_cta_text || 'Request a Free Estimate'
const ctaLink = settings.data.footer_cta_link || '/contact'
const navLinks = settings.data.nav_links || []
---

<footer class="bg-primary-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Company -->
      <div>
        <img src="/images/logo-footer.png" alt={companyName} class="w-full mb-4 bg-white rounded-lg p-3" />
        <p class="text-white/70 text-sm leading-relaxed">{description}</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {navLinks.filter((item) => item.label !== 'Home').map((item) => (
            <li>
              <a
                href={item.url || '/'}
                class="text-white/70 hover:text-accent text-sm transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-bold mb-4">Get In Touch</h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li>📞 {phone}</li>
          <li>✉️ {email}</li>
          <li>📍 {location}</li>
        </ul>
        <a
          href={ctaLink}
          class="inline-block mt-4 bg-accent hover:bg-accent-light text-primary-dark px-5 py-2 rounded-lg text-sm font-bold transition-colors"
        >
          {ctaText}
        </a>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-8 text-center text-sm text-white/50">
      &copy; {currentYear} {companyName}. All rights reserved.
    </div>
  </div>
</footer>
