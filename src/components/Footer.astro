---
import { getEntry, getCollection } from 'astro:content'

const settings = await getEntry('settings', 'global')
const activeProjects = await getCollection('projects', ({ data }) => data.active !== false)
const currentYear = new Date().getFullYear()
const companyName = settings.data.company_name || 'Deep Roots Drainage'
const phone = settings.data.phone || '(701) 555-0123'
const email = settings.data.email || 'info@deeprootsdrainage.com'
const location = settings.data.location || 'North Dakota'
const description = settings.data.footer_description || ''
const ctaText = settings.data.footer_cta_text || 'Request a Free Estimate'
const ctaLink = settings.data.footer_cta_link || '/contact'
const allNavLinks = settings.data.nav_links || []
const navLinks = allNavLinks.filter(link => link.url !== '/projects' || activeProjects.length > 0)
const socialLinks = [
  {
    label: 'Facebook',
    brandText: 'facebook',
    url: 'https://www.facebook.com/profile.php?id=61589146087600',
    className: 'from-[#1877F2] to-[#0B5ED7] text-white',
    iconClassName: 'text-[#1877F2]',
    iconPath:
      'M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.19 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.5-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.47H15.2c-1.24 0-1.63.78-1.63 1.57v1.89h2.77l-.44 2.91h-2.33V22C18.34 21.25 22 17.08 22 12.06Z',
  },
  {
    label: 'Instagram',
    brandText: 'Instagram',
    url: 'https://www.instagram.com/deeprootsdrainage/',
    className: 'from-[#FEDA75] via-[#D62976] to-[#4F5BD5] text-white',
    iconClassName: 'text-[#D62976]',
    iconPath:
      'M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8Zm8.95 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z',
  },
]
---

<footer class="bg-primary-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Company -->
      <div>
        <img src="/images/logo-footer.png" alt={companyName} class="w-full mb-4" />
        <p class="text-white/70 text-sm leading-relaxed">{description}</p>
        <div class="mt-6">
          <div class="grid w-full max-w-sm grid-cols-1 gap-3 sm:grid-cols-2 md:grid-cols-1 xl:grid-cols-2">
          {socialLinks.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${companyName} on ${item.label}`}
              class="group inline-flex h-14 w-full min-w-0 items-stretch transition-transform hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            >
              <span class="relative z-10 flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-white shadow-sm ring-1 ring-white/70">
                <svg
                  aria-hidden="true"
                  class:list={['h-7 w-7', item.iconClassName]}
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d={item.iconPath}></path>
                </svg>
              </span>
              <span
                class:list={[
                  '-ml-7 flex min-w-0 flex-1 items-center rounded-r-lg bg-gradient-to-r py-2 pl-10 pr-4 text-white shadow-lg shadow-black/20 ring-1 ring-white/20 group-hover:shadow-xl',
                  item.className,
                ]}
              >
                <span class="min-w-0 leading-none">
                  <span class="block text-[11px] font-semibold">Follow us on</span>
                  <span class="block text-xl font-extrabold">{item.brandText}</span>
                </span>
              </span>
            </a>
          ))}
          </div>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {navLinks.filter((item) => item.label !== 'Home').map((item) => (
            <li>
              <a
                href={item.url || '/'}
                class="text-white/70 hover:text-accent text-sm transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-bold mb-4">Get In Touch</h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li>📞 {phone}</li>
          <li>✉️ {email}</li>
          <li>📍 {location}</li>
        </ul>
        <a
          href={ctaLink}
          class="inline-block mt-4 bg-accent hover:bg-accent-light text-primary-dark px-5 py-2 rounded-lg text-sm font-bold transition-colors"
        >
          {ctaText}
        </a>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-8 text-center text-sm text-white/50">
      &copy; {currentYear} {companyName}. All rights reserved.
    </div>
  </div>
</footer>

<script is:inline async src="https://js.adsrvr.org/up_loader.3.0.0.js"></script>
<script is:inline>
  window.ttdConversionEventsLayer = window.ttdConversionEventsLayer || [];
  function ttdConversionEvents() {
    window.ttdConversionEventsLayer.push(arguments);
  }

  ttdConversionEvents("init", {
    advertiserId: "e449gg6",
    pixelIds: ["lcis84n"]
  });

  ttdConversionEvents("event", {
    advertiserId: "e449gg6",
    pixelIds: ["lcis84n"]
  });
</script>
