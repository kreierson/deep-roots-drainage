---
import { getEntry, getCollection } from 'astro:content'

const settings = await getEntry('settings', 'global')
const activeProjects = await getCollection('projects', ({ data }) => data.active !== false)
const allNavLinks = settings.data.nav_links || []
const navLinks = allNavLinks.filter(link => link.url !== '/projects' || activeProjects.length > 0)
const ctaText = settings.data.cta_button_text || 'Free Estimate'
const ctaLink = settings.data.cta_button_link || '/contact'
const companyName = settings.data.company_name || 'Deep Roots Drainage'
const tagline = settings.data.tagline || 'Drainage'
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center -my-4">
        <img src="/images/logo.png" alt={companyName} class="w-48 md:w-56" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((item) => (
          <a
            href={item.url || '/'}
            class="text-sm font-semibold text-gray-600 hover:text-primary transition-colors"
          >
            {item.label}
          </a>
        ))}
        <a
          href={ctaLink}
          class="bg-accent-red hover:bg-red-700 text-white px-6 py-2.5 rounded-lg text-sm font-bold transition-colors"
        >
          {ctaText}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-gray-600"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      {navLinks.map((item) => (
        <a
          href={item.url || '/'}
          class="block py-2 text-sm font-semibold text-gray-600 hover:text-primary"
        >
          {item.label}
        </a>
      ))}
      <a
        href={ctaLink}
        class="block mt-2 bg-accent-red text-white text-center px-6 py-2.5 rounded-lg text-sm font-bold"
      >
        {ctaText}
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'))
</script>
