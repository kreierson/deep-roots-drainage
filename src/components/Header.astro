---
import { getSettings } from '../lib/settings'

const settings = await getSettings()
const navLinks = settings.nav_links || []
const ctaText = settings.cta_button_text || 'Free Estimate'
const ctaLink = settings.cta_button_link?.url || settings.cta_button_link?.cached_url || '/contact'
const companyName = settings.company_name || 'Deep Roots Drainage'
const tagline = settings.tagline || 'Drainage'
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-lg">DR</span>
        </div>
        <div>
          <span class="text-xl font-bold text-primary">{companyName.split(' ').slice(0, 2).join(' ')}</span>
          <span class="block text-xs text-earth font-medium -mt-1">{companyName.split(' ').slice(2).join(' ') || tagline}</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((item: any) => (
          <a
            href={item.link?.url || item.link?.cached_url || '/'}
            class="text-sm font-semibold text-gray-600 hover:text-primary transition-colors"
          >
            {item.label}
          </a>
        ))}
        <a
          href={ctaLink}
          class="bg-primary hover:bg-primary-light text-white px-6 py-2.5 rounded-lg text-sm font-bold transition-colors"
        >
          {ctaText}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-gray-600"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      {navLinks.map((item: any) => (
        <a
          href={item.link?.url || item.link?.cached_url || '/'}
          class="block py-2 text-sm font-semibold text-gray-600 hover:text-primary"
        >
          {item.label}
        </a>
      ))}
      <a
        href={ctaLink}
        class="block mt-2 bg-primary text-white text-center px-6 py-2.5 rounded-lg text-sm font-bold"
      >
        {ctaText}
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'))
</script>
