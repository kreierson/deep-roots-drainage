---
import { getEntry, getCollection } from 'astro:content'

const settings = await getEntry('settings', 'global')
const activeProjects = await getCollection('projects', ({ data }) => data.active !== false)
const allNavLinks = settings.data.nav_links || []
const navLinks = allNavLinks.filter(link => link.url !== '/projects' || activeProjects.length > 0)
const ctaText = settings.data.cta_button_text || 'Free Estimate'
const ctaLink = settings.data.cta_button_link || '/contact'
const companyName = settings.data.company_name || 'Deep Roots Drainage'
const tagline = settings.data.tagline || 'Drainage'
const phone = settings.data.phone || ''
const email = settings.data.email || ''
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-[60]">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center -my-2">
        <img src="/images/logo.png" alt={companyName} class="h-20" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((item) => (
          <a
            href={item.url || '/'}
            class="text-sm font-semibold text-gray-600 hover:text-primary transition-colors"
          >
            {item.label}
          </a>
        ))}
        <a
          href={ctaLink}
          class="bg-accent-red hover:bg-red-700 text-white px-6 py-2.5 rounded-lg text-sm font-bold transition-colors"
        >
          {ctaText}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden relative w-10 h-10 flex items-center justify-center"
        aria-label="Toggle menu"
      >
        <span id="hamburger-top" class="absolute w-6 h-0.5 bg-gray-700 transition-all duration-300 -translate-y-2"></span>
        <span id="hamburger-mid" class="absolute w-6 h-0.5 bg-gray-700 transition-all duration-300"></span>
        <span id="hamburger-bot" class="absolute w-6 h-0.5 bg-gray-700 transition-all duration-300 translate-y-2"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Nav Overlay -->
<div id="mobile-menu" class="fixed inset-0 top-20 z-50 pointer-events-none opacity-0 transition-opacity duration-300 md:hidden">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-primary-dark/95 backdrop-blur-sm"></div>
  
  <!-- Content -->
  <div class="relative h-full flex flex-col px-8 pt-8 pb-8">
    <!-- Nav Links -->
    <nav class="flex-1 flex flex-col justify-center -mt-16">
      {navLinks.map((item, i) => (
        <a
          href={item.url || '/'}
          class="mobile-nav-link block py-4 text-2xl font-bold text-white/90 hover:text-accent border-b border-white/10 transition-all duration-300"
          style={`transition-delay: ${i * 50}ms; opacity: 0; transform: translateX(-20px);`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA Button -->
    <div class="mobile-nav-link" style={`transition-delay: ${navLinks.length * 50}ms; opacity: 0; transform: translateY(10px);`}>
      <a
        href={ctaLink}
        class="block w-full bg-accent-red hover:bg-red-700 text-white text-center px-6 py-4 rounded-xl text-lg font-bold transition-colors"
      >
        {ctaText}
      </a>
    </div>

    <!-- Contact Info -->
    <div class="mobile-nav-link mt-6 flex flex-col gap-3" style={`transition-delay: ${(navLinks.length + 1) * 50}ms; opacity: 0; transform: translateY(10px);`}>
      {phone && (
        <a href={`tel:${phone.replace(/[^+\d]/g, '')}`} class="flex items-center gap-3 text-white/60 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span class="text-sm font-medium">{phone}</span>
        </a>
      )}
      {email && (
        <a href={`mailto:${email}`} class="flex items-center gap-3 text-white/60 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span class="text-sm font-medium">{email}</span>
        </a>
      )}
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const top = document.getElementById('hamburger-top')
  const mid = document.getElementById('hamburger-mid')
  const bot = document.getElementById('hamburger-bot')
  const links = menu?.querySelectorAll('.mobile-nav-link')
  let open = false
  let savedScrollY = 0

  btn?.addEventListener('click', () => {
    open = !open
    if (open) {
      savedScrollY = window.scrollY
      menu?.classList.remove('pointer-events-none', 'opacity-0')
      menu?.classList.add('pointer-events-auto', 'opacity-100')
      // Animate hamburger to X
      top?.classList.add('translate-y-0', 'rotate-45')
      top?.classList.remove('-translate-y-2')
      mid?.classList.add('opacity-0')
      bot?.classList.add('translate-y-0', '-rotate-45')
      bot?.classList.remove('translate-y-2')
      // Stagger link animations
      links?.forEach(link => {
        (link as HTMLElement).style.opacity = '1';
        (link as HTMLElement).style.transform = 'translateX(0) translateY(0)';
      })
      // Lock body scroll (works on iOS Safari too)
      document.body.style.overflow = 'hidden'
      document.body.style.position = 'fixed'
      document.body.style.width = '100%'
      document.body.style.top = `-${window.scrollY}px`
    } else {
      menu?.classList.add('pointer-events-none', 'opacity-0')
      menu?.classList.remove('pointer-events-auto', 'opacity-100')
      // Animate X back to hamburger
      top?.classList.remove('translate-y-0', 'rotate-45')
      top?.classList.add('-translate-y-2')
      mid?.classList.remove('opacity-0')
      bot?.classList.remove('translate-y-0', '-rotate-45')
      bot?.classList.add('translate-y-2')
      // Reset links
      links?.forEach((link, i) => {
        (link as HTMLElement).style.opacity = '0';
        (link as HTMLElement).style.transform = i < (links.length - 2) ? 'translateX(-20px)' : 'translateY(10px)';
      })
      // Restore scroll
      document.body.style.overflow = ''
      document.body.style.position = ''
      document.body.style.width = ''
      document.body.style.top = ''
      window.scrollTo(0, savedScrollY)
    }
  })
</script>
