---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
  const careers = await getCollection('careers')
  return careers
    .filter((job) => job.data.active)
    .map((job) => ({
      params: { slug: job.slug },
      props: { job },
    }))
}

const { job } = Astro.props
const { data } = job
const { Content } = await job.render()

const postedDate = new Date(data.posted_date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<Layout title={data.title} description={data.summary}>
  <article class="min-h-screen">
    <section class="relative py-28 md:py-36 overflow-hidden">
      <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1400&q=80" alt="Heavy equipment at work" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/80 via-primary-dark/50 to-primary-dark/20"></div>
      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-4">
          <a href="/careers" class="hover:text-accent-light transition-colors">Careers</a>
          <span>•</span>
          <span>{data.type}</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-white leading-tight mb-6">{data.title}</h1>
        <p class="text-white/80 text-xl leading-relaxed max-w-2xl">{data.summary}</p>

        <div class="flex flex-wrap gap-6 mt-8 text-white/90">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium">{data.location}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium">Posted {postedDate}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>

        <div class="bg-surface rounded-2xl p-8 mt-12 text-center">
          <h2 class="text-2xl font-black text-gray-900 mb-4">Interested in This Position?</h2>
          <p class="text-gray-600 mb-6">Send us a message and tell us about yourself. We'd love to hear from you.</p>
          <a href={`/careers/apply?position=${encodeURIComponent(data.title)}`} class="inline-block bg-primary hover:bg-primary-light text-white px-8 py-4 rounded-lg font-bold text-lg transition-colors">
            Apply Now →
          </a>
        </div>
      </div>
    </section>
  </article>
</Layout>
