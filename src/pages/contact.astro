---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Contact" description="Get a free drain tile estimate from Deep Roots Drainage. Serving all of North Dakota.">
  <section class="bg-primary-dark py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-accent font-semibold text-sm tracking-wider uppercase mb-2">Let's Talk</p>
      <h1 class="text-4xl md:text-5xl font-black text-white">Get Your Free Estimate</h1>
      <p class="mt-4 text-white/70 text-lg">Tell us about your project and we'll get back to you within 24 hours.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">Phone *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                  placeholder="(701) 555-0123"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                placeholder="you@email.com"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-semibold text-gray-700 mb-1">Service Needed</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition bg-white"
              >
                <option value="">Select a service...</option>
                <option value="exterior">Exterior Drain Tile</option>
                <option value="interior">Interior Drain Tile</option>
                <option value="waterproofing">Foundation Waterproofing</option>
                <option value="sump">Sump Pump Install/Repair</option>
                <option value="other">Not Sure / Other</option>
              </select>
            </div>

            <div>
              <label for="city" class="block text-sm font-semibold text-gray-700 mb-1">City / Area</label>
              <input
                type="text"
                id="city"
                name="city"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                placeholder="e.g. Fargo, Bismarck, Grand Forks"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">Tell Us About Your Project</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition resize-y"
                placeholder="Describe your water/drainage issues, property type, etc."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-primary hover:bg-primary-light text-white py-4 rounded-lg font-bold text-lg transition-colors"
            >
              Request Free Estimate
            </button>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-surface rounded-2xl p-8">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Contact Info</h3>
            <ul class="space-y-4 text-gray-600">
              <li class="flex items-start gap-3">
                <span class="text-xl">📞</span>
                <div>
                  <p class="font-semibold text-gray-900">(701) 555-0123</p>
                  <p class="text-sm">Call or text anytime</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-xl">✉️</span>
                <div>
                  <p class="font-semibold text-gray-900">info@deeprootsdrainage.com</p>
                  <p class="text-sm">We reply within 24 hours</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-xl">📍</span>
                <div>
                  <p class="font-semibold text-gray-900">Serving All of North Dakota</p>
                  <p class="text-sm">Fargo, Bismarck, Grand Forks, Minot & beyond</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="bg-primary/5 rounded-2xl p-8 border border-primary/10">
            <h3 class="text-lg font-bold text-gray-900 mb-2">What to Expect</h3>
            <ol class="space-y-3 text-gray-600 text-sm">
              <li class="flex gap-3">
                <span class="bg-primary text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0">1</span>
                <span>We'll call you within 24 hours to discuss your project</span>
              </li>
              <li class="flex gap-3">
                <span class="bg-primary text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0">2</span>
                <span>Schedule a free on-site assessment</span>
              </li>
              <li class="flex gap-3">
                <span class="bg-primary text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0">3</span>
                <span>Receive a detailed quote with no hidden fees</span>
              </li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
