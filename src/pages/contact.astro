---
import Layout from '../layouts/Layout.astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'


const token = import.meta.env.STORYBLOK_TOKEN || 'KAaKAIFtzAtyOal659brwAtt'
const version = import.meta.env.DEV ? 'draft' : 'published'
const cv = Date.now()

let story = null
try {
  const url = `https://api.storyblok.com/v2/cdn/stories/contact?version=${version}&token=${token}&cv=${cv}`
  const res = await fetch(url)
  const json = await res.json()
  story = json.story
} catch (e: any) {
  console.error(`[contact] Failed:`, e.message)
}

const seo = story?.content?.seo_title ? story.content : null
---

{story ? (
  <Layout title={seo?.seo_title || 'Contact'} description={seo?.seo_description}>
    <StoryblokComponent blok={story.content} />
  </Layout>
) : (
<Layout title="Contact" description="Get a free drain tile estimate from Deep Roots Drainage. Serving farmers and landowners across North Dakota.">
  <section class="relative py-28 md:py-36 overflow-hidden">
    <img src="https://images.unsplash.com/photo-1586771107445-d3ca888129ff?w=1400&q=80" alt="Rural farmland in North Dakota" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/70 via-primary-dark/50 to-primary-dark/30"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">Let's Talk</p>
      <h1 class="text-4xl md:text-5xl font-black text-white">Get Your Free Estimate</h1>
      <p class="mt-4 text-white/80 text-lg">Tell us about your land and we'll get back to you within 24 hours.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        <div class="lg:col-span-3">
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Name *</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" placeholder="Your name" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">Phone *</label>
                <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" placeholder="(701) 555-0123" />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
              <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" placeholder="you@email.com" />
            </div>
            <div>
              <label for="service" class="block text-sm font-semibold text-gray-700 mb-1">What Do You Need?</label>
              <select id="service" name="service" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition bg-white">
                <option value="">Select a service...</option>
                <option value="pattern">Pattern Tile System</option>
                <option value="mains">Main / Submain Lines</option>
                <option value="outlet">Outlet Construction</option>
                <option value="survey">Survey & Design Only</option>
                <option value="repair">Tile Repair / Maintenance</option>
                <option value="other">Not Sure / Other</option>
              </select>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="location" class="block text-sm font-semibold text-gray-700 mb-1">County / Area</label>
                <input type="text" id="location" name="location" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" placeholder="e.g. Cass County, near Fargo" />
              </div>
              <div>
                <label for="acres" class="block text-sm font-semibold text-gray-700 mb-1">Approx. Acres</label>
                <input type="text" id="acres" name="acres" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" placeholder="e.g. 160, 320, full section" />
              </div>
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">Tell Us About Your Project</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition resize-y" placeholder="Describe your drainage issues — wet spots, ponding areas, what crops you're running, etc."></textarea>
            </div>
            <button type="submit" class="w-full bg-primary hover:bg-primary-light text-white py-4 rounded-lg font-bold text-lg transition-colors">Request Free Estimate</button>
          </form>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="bg-surface rounded-2xl p-8">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Contact Info</h3>
            <ul class="space-y-4 text-gray-600">
              <li class="flex items-start gap-3"><span class="text-xl">📞</span><div><p class="font-semibold text-gray-900">(701) 555-0123</p><p class="text-sm">Call or text</p></div></li>
              <li class="flex items-start gap-3"><span class="text-xl">✉️</span><div><p class="font-semibold text-gray-900">info@deeprootsdrainage.com</p><p class="text-sm">We reply within 24 hours</p></div></li>
              <li class="flex items-start gap-3"><span class="text-xl">📍</span><div><p class="font-semibold text-gray-900">Serving All of North Dakota</p><p class="text-sm">Based in [City], available statewide</p></div></li>
            </ul>
          </div>

          <div class="bg-primary/5 rounded-2xl p-8 border border-primary/10">
            <h3 class="text-lg font-bold text-gray-900 mb-2">What to Expect</h3>
            <ol class="space-y-3 text-gray-600 text-sm">
              <li class="flex gap-3"><span class="bg-primary text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0">1</span><span>We'll call to discuss your land and drainage goals</span></li>
              <li class="flex gap-3"><span class="bg-primary text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0">2</span><span>Schedule a field survey and walk-through</span></li>
              <li class="flex gap-3"><span class="bg-primary text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0">3</span><span>Receive a custom drainage design and detailed quote</span></li>
            </ol>
          </div>

          <div class="bg-accent/10 rounded-2xl p-8 border border-accent/20">
            <h3 class="text-lg font-bold text-gray-900 mb-2">💡 Planning Ahead?</h3>
            <p class="text-gray-600 text-sm leading-relaxed">The best time to plan a tile project is well before installation season. Contact us now to get on the schedule — fall and spring slots fill up fast.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
)}
