---
import Layout from '../layouts/Layout.astro'
import { getEntry, getCollection } from 'astro:content'

const homeContent = await getEntry('pages', 'home')
const { Content, data } = homeContent

const allProjects = await getCollection('projects')
const featuredProjects = allProjects.filter(p => p.data.featured).sort((a, b) => b.data.year - a.data.year)
---
<Layout title={data.seo_title || data.title} description={data.seo_description}>

  <!-- ═══════════ HERO — full-bleed background image ═══════════ -->
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <img
      src={data.hero.image}
      alt={data.hero.image_alt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-primary-dark/60 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/70 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 w-full">
      <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-4">{data.hero.eyebrow}</p>
      <h1 class="text-5xl md:text-7xl font-black text-white leading-[1.05] max-w-3xl" set:html={data.hero.title}></h1>
      <p class="mt-6 text-lg md:text-xl text-white/85 leading-relaxed max-w-xl">
        {data.hero.description}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href={data.hero.primary_button.url} class="bg-accent hover:bg-accent-light text-primary-dark px-8 py-4 rounded-lg font-bold text-lg text-center transition-colors shadow-lg">{data.hero.primary_button.text}</a>
        {data.hero.secondary_button && (
          <a href={data.hero.secondary_button.url} class="border-2 border-white/30 hover:border-white/60 text-white px-8 py-4 rounded-lg font-bold text-center transition-colors backdrop-blur-sm">{data.hero.secondary_button.text}</a>
        )}
      </div>
    </div>
  </section>

  <!-- ═══════════ STATS BAR ═══════════ -->
  <section class="bg-primary-dark border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {data.stats.map((stat, index) => (
          <div class={`${index !== data.stats.length - 1 ? 'border-r border-white/10' : ''}`}>
            <p class="text-2xl md:text-3xl font-black text-accent">{stat.value}</p>
            <p class="text-xs text-white/60 font-medium mt-1 uppercase tracking-wider">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ BEFORE / AFTER ═══════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-14">
        <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{data.before_after.eyebrow}</p>
        <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight">{data.before_after.title}</h2>
        <p class="mt-4 text-gray-600 text-lg">{data.before_after.description}</p>
      </div>
      <div class="grid md:grid-cols-2 gap-3">
        <div class="relative rounded-2xl overflow-hidden group">
          <img
            src={data.before_after.before_image}
            alt={data.before_after.before_image_alt}
            class="w-full h-72 md:h-96 object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-red-900/80 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="inline-block bg-red-600 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">Before</span>
            <p class="text-white font-bold text-xl">{data.before_after.before_title}</p>
            <p class="text-white/70 text-sm mt-1">{data.before_after.before_description}</p>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden group">
          <img
            src={data.before_after.after_image}
            alt={data.before_after.after_image_alt}
            class="w-full h-72 md:h-96 object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/80 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="inline-block bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">After</span>
            <p class="text-white font-bold text-xl">{data.before_after.after_title}</p>
            <p class="text-white/70 text-sm mt-1">{data.before_after.after_description}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ HOW IT WORKS — asymmetric layout ═══════════ -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Image side -->
        <div class="relative">
          <img
            src={data.how_it_works.image}
            alt={data.how_it_works.image_alt}
            class="rounded-2xl shadow-2xl w-full h-[500px] object-cover"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -right-6 bg-accent text-primary-dark rounded-xl px-6 py-4 shadow-lg hidden md:block">
            <p class="text-3xl font-black">{data.how_it_works.steps.length}</p>
            <p class="text-sm font-bold">Simple Steps</p>
          </div>
        </div>
        <!-- Steps side -->
        <div>
          <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{data.how_it_works.eyebrow}</p>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-10">{data.how_it_works.title}</h2>
          <div class="space-y-8">
            {data.how_it_works.steps.map((step, index) => (
              <div class="flex gap-5">
                <div class={`flex-shrink-0 w-12 h-12 rounded-full ${index === data.how_it_works.steps.length - 1 ? 'bg-accent text-primary-dark' : 'bg-primary text-white'} flex items-center justify-center font-black text-lg`}>
                  {index === data.how_it_works.steps.length - 1 ? '✓' : index + 1}
                </div>
                <div>
                  <h3 class="font-bold text-lg text-gray-900">{step.title}</h3>
                  <p class="text-gray-600 mt-1">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ SOCIAL PROOF — topo background ═══════════ -->
  <section class="relative py-24 bg-primary-dark overflow-hidden">
    <!-- Topographic SVG pattern -->
    <div class="absolute inset-0 opacity-[0.07]">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
        <g fill="none" stroke="white" stroke-width="1.5">
          <ellipse cx="400" cy="300" rx="380" ry="260"/>
          <ellipse cx="400" cy="300" rx="340" ry="230"/>
          <ellipse cx="400" cy="300" rx="300" ry="200"/>
          <ellipse cx="400" cy="300" rx="260" ry="170"/>
          <ellipse cx="400" cy="300" rx="220" ry="140"/>
          <ellipse cx="400" cy="300" rx="180" ry="110"/>
          <ellipse cx="400" cy="300" rx="140" ry="80"/>
          <ellipse cx="400" cy="300" rx="100" ry="55"/>
          <ellipse cx="400" cy="300" rx="60" ry="30"/>
          <ellipse cx="200" cy="150" rx="160" ry="110"/>
          <ellipse cx="200" cy="150" rx="120" ry="80"/>
          <ellipse cx="200" cy="150" rx="80" ry="50"/>
          <ellipse cx="200" cy="150" rx="40" ry="22"/>
          <ellipse cx="650" cy="450" rx="140" ry="100"/>
          <ellipse cx="650" cy="450" rx="100" ry="70"/>
          <ellipse cx="650" cy="450" rx="60" ry="40"/>
        </g>
      </svg>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{data.social_proof.eyebrow}</p>
        <h2 class="text-3xl md:text-5xl font-black text-white">{data.social_proof.title}</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {data.social_proof.stats.map((stat) => (
          <div class="text-center">
            <p class="text-5xl md:text-6xl font-black text-accent" set:html={stat.value.includes('+') ? stat.value.replace('+', '<span class="text-3xl">+</span>') : stat.value.includes('%') ? stat.value.replace('%', '<span class="text-3xl">%</span>') : stat.value}></p>
            <p class="text-white/70 mt-2 font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ TESTIMONIALS — infinite scroll ═══════════ -->
  <section class="py-24 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-14">
        <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{data.testimonials.eyebrow}</p>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900">{data.testimonials.title}</h2>
      </div>
    </div>
    <div class="testimonial-carousel relative">
      <div class="testimonial-track flex gap-6">
        {/* Render items twice for seamless infinite loop */}
        {[...data.testimonials.items, ...data.testimonials.items].map((testimonial) => (
          <div class="bg-surface rounded-2xl p-8 relative flex-shrink-0 w-[350px] md:w-[400px]">
            <svg class="w-10 h-10 text-accent/30 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-gray-700 leading-relaxed mb-6">"{testimonial.quote}"</p>
            <div class="border-t border-surface-dark pt-4">
              <p class="font-bold text-gray-900">{testimonial.name}</p>
              <p class="text-sm text-gray-500">{testimonial.location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .testimonial-carousel {
      mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }
    .testimonial-track {
      animation: scroll-left var(--scroll-duration, 40s) linear infinite;
      width: max-content;
    }
    .testimonial-track:hover {
      animation-play-state: paused;
    }
    @keyframes scroll-left {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

  <script define:vars={{ itemCount: data.testimonials.items.length }}>
    // Scale duration based on number of items so speed stays consistent
    const duration = Math.max(20, itemCount * 8);
    document.querySelector('.testimonial-track').style.setProperty('--scroll-duration', duration + 's');
  </script>

  <!-- ═══════════ FEATURED PROJECTS ═══════════ -->
  {featuredProjects.length > 0 && (
    <section class="py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mb-14">
          <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">Our Work</p>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900">Featured Projects</h2>
          <p class="mt-4 text-gray-600 text-lg">Real results from real farms across North Dakota.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map((project) => (
            <a href={`/projects/${project.slug}`} class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow group flex flex-col cursor-pointer">
              <div class="relative h-48 overflow-hidden">
                <img
                  src={project.data.featured_image}
                  alt={project.data.featured_image_alt}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute top-4 left-4">
                  <span class="bg-primary text-white px-3 py-1 rounded-full text-sm font-bold">
                    {project.data.year}
                  </span>
                </div>
              </div>
              <div class="p-6 flex flex-col flex-1">
                <h3 class="text-xl font-bold text-gray-900 mb-2 leading-tight">
                  {project.data.title}
                </h3>
                <p class="text-gray-600 text-sm mb-4 flex-1 line-clamp-3">
                  {project.data.summary}
                </p>
                <div class="flex items-center justify-between text-sm text-gray-500">
                  <span>📍 {project.data.location}</span>
                  <span>🌾 {project.data.acres} acres</span>
                </div>
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/projects" class="inline-block border-2 border-primary text-primary hover:bg-primary hover:text-white px-8 py-3 rounded-lg font-bold transition-colors">
            View All Projects →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════ CTA ═══════════ -->
  <section class="relative py-24 overflow-hidden">
    <img
      src={data.cta.image}
      alt={data.cta.image_alt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-primary-dark/85"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-black text-white mb-4">{data.cta.title}</h2>
      <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto">{data.cta.description}</p>
      <a href={data.cta.button_url} class="inline-block bg-accent hover:bg-accent-light text-primary-dark px-10 py-4 rounded-lg font-bold text-lg transition-colors shadow-xl">{data.cta.button_text}</a>
    </div>
  </section>

</Layout>
