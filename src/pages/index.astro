---
import Layout from '../layouts/Layout.astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'
import { useStoryblokApi } from '@storyblok/astro'

let story = null
try {
  const storyblokApi = useStoryblokApi()
  const { data } = await storyblokApi.get('cdn/stories/home', {
    version: import.meta.env.DEV ? 'draft' : 'published',
  })
  story = data.story
} catch (e) {
  // Storyblok not seeded yet — fall through to hardcoded
}

const seo = story?.content?.seo_title ? story.content : null
---

{story ? (
  <Layout title={seo?.seo_title || 'Home'} description={seo?.seo_description}>
    <StoryblokComponent blok={story.content} />
  </Layout>
) : (
<Layout title="Home">

  <!-- ═══════════ HERO — full-bleed background image ═══════════ -->
  <section class="relative min-h-[85vh] flex items-end overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1920&q=80"
      alt="Golden wheat field at sunrise across North Dakota farmland"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-primary-dark/60 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/70 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 pt-40 w-full">
      <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-4">Agricultural Drainage · North Dakota</p>
      <h1 class="text-5xl md:text-7xl font-black text-white leading-[1.05] max-w-3xl">
        Better Drainage.<br/>Better Yields.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-white/85 leading-relaxed max-w-xl">
        Professional drain tile installation that turns waterlogged acres into your most productive ground.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="bg-accent hover:bg-accent-light text-primary-dark px-8 py-4 rounded-lg font-bold text-lg text-center transition-colors shadow-lg">Get a Free Estimate</a>
        <a href="/services" class="border-2 border-white/30 hover:border-white/60 text-white px-8 py-4 rounded-lg font-bold text-center transition-colors backdrop-blur-sm">Our Services</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ STATS BAR ═══════════ -->
  <section class="bg-primary-dark border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="border-r border-white/10 last:border-0"><p class="text-2xl md:text-3xl font-black text-accent">GPS</p><p class="text-xs text-white/60 font-medium mt-1 uppercase tracking-wider">Guided Installation</p></div>
        <div class="border-r border-white/10 last:border-0"><p class="text-2xl md:text-3xl font-black text-accent">24hr</p><p class="text-xs text-white/60 font-medium mt-1 uppercase tracking-wider">Quote Turnaround</p></div>
        <div class="border-r border-white/10 last:border-0"><p class="text-2xl md:text-3xl font-black text-accent">Licensed</p><p class="text-xs text-white/60 font-medium mt-1 uppercase tracking-wider">& Fully Insured</p></div>
        <div><p class="text-2xl md:text-3xl font-black text-accent">Local</p><p class="text-xs text-white/60 font-medium mt-1 uppercase tracking-wider">North Dakota Owned</p></div>
      </div>
    </div>
  </section>

  <!-- ═══════════ BEFORE / AFTER ═══════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-14">
        <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">The Difference</p>
        <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight">See What Drainage Can Do</h2>
        <p class="mt-4 text-gray-600 text-lg">The same land, dramatically different results. Drain tile transforms waterlogged fields into high-performing acres.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-3">
        <div class="relative rounded-2xl overflow-hidden group">
          <img
            src="https://images.unsplash.com/photo-1530836369250-ef72a3f5cda8?w=800&q=80"
            alt="Waterlogged, flooded farmland with standing water"
            class="w-full h-72 md:h-96 object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-red-900/80 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="inline-block bg-red-600 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">Before</span>
            <p class="text-white font-bold text-xl">Standing Water & Lost Acres</p>
            <p class="text-white/70 text-sm mt-1">Saturated soil, delayed planting, reduced yields</p>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden group">
          <img
            src="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?w=800&q=80"
            alt="Healthy green crop rows in a well-drained field"
            class="w-full h-72 md:h-96 object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-green-900/80 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="inline-block bg-green-600 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">After</span>
            <p class="text-white font-bold text-xl">Productive, Drained Ground</p>
            <p class="text-white/70 text-sm mt-1">Earlier planting, healthier soil, 15-30% higher yields</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ HOW IT WORKS — asymmetric layout ═══════════ -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Image side -->
        <div class="relative">
          <img
            src="https://images.unsplash.com/photo-1560493676-04071c5f467b?w=800&q=80"
            alt="Aerial view of cultivated agricultural field rows"
            class="rounded-2xl shadow-2xl w-full h-[500px] object-cover"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -right-6 bg-accent text-primary-dark rounded-xl px-6 py-4 shadow-lg hidden md:block">
            <p class="text-3xl font-black">4</p>
            <p class="text-sm font-bold">Simple Steps</p>
          </div>
        </div>
        <!-- Steps side -->
        <div>
          <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">How It Works</p>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-10">From Survey to Results</h2>
          <div class="space-y-8">
            <div class="flex gap-5">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center font-black text-lg">1</div>
              <div>
                <h3 class="font-bold text-lg text-gray-900">Survey Your Land</h3>
                <p class="text-gray-600 mt-1">We walk your fields, review topography, and identify problem areas with GPS mapping.</p>
              </div>
            </div>
            <div class="flex gap-5">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center font-black text-lg">2</div>
              <div>
                <h3 class="font-bold text-lg text-gray-900">Design the System</h3>
                <p class="text-gray-600 mt-1">Custom tile layout engineered for your specific soil type, field slope, and drainage needs.</p>
              </div>
            </div>
            <div class="flex gap-5">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center font-black text-lg">3</div>
              <div>
                <h3 class="font-bold text-lg text-gray-900">Install with Precision</h3>
                <p class="text-gray-600 mt-1">GPS-guided installation ensures accurate grade and depth. Minimal disruption to your operation.</p>
              </div>
            </div>
            <div class="flex gap-5">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent text-primary-dark flex items-center justify-center font-black text-lg">✓</div>
              <div>
                <h3 class="font-bold text-lg text-gray-900">See the Results</h3>
                <p class="text-gray-600 mt-1">Drier fields, earlier planting, and yields that prove the investment — often within the first season.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ SOCIAL PROOF — topo background ═══════════ -->
  <section class="relative py-24 bg-primary-dark overflow-hidden">
    <!-- Topographic SVG pattern -->
    <div class="absolute inset-0 opacity-[0.07]">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
        <g fill="none" stroke="white" stroke-width="1.5">
          <ellipse cx="400" cy="300" rx="380" ry="260"/>
          <ellipse cx="400" cy="300" rx="340" ry="230"/>
          <ellipse cx="400" cy="300" rx="300" ry="200"/>
          <ellipse cx="400" cy="300" rx="260" ry="170"/>
          <ellipse cx="400" cy="300" rx="220" ry="140"/>
          <ellipse cx="400" cy="300" rx="180" ry="110"/>
          <ellipse cx="400" cy="300" rx="140" ry="80"/>
          <ellipse cx="400" cy="300" rx="100" ry="55"/>
          <ellipse cx="400" cy="300" rx="60" ry="30"/>
          <ellipse cx="200" cy="150" rx="160" ry="110"/>
          <ellipse cx="200" cy="150" rx="120" ry="80"/>
          <ellipse cx="200" cy="150" rx="80" ry="50"/>
          <ellipse cx="200" cy="150" rx="40" ry="22"/>
          <ellipse cx="650" cy="450" rx="140" ry="100"/>
          <ellipse cx="650" cy="450" rx="100" ry="70"/>
          <ellipse cx="650" cy="450" rx="60" ry="40"/>
        </g>
      </svg>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">By the Numbers</p>
        <h2 class="text-3xl md:text-5xl font-black text-white">Proven Results Across ND</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <p class="text-5xl md:text-6xl font-black text-accent">15<span class="text-3xl">+</span></p>
          <p class="text-white/70 mt-2 font-medium">Years Experience</p>
        </div>
        <div class="text-center">
          <p class="text-5xl md:text-6xl font-black text-accent">500<span class="text-3xl">+</span></p>
          <p class="text-white/70 mt-2 font-medium">Miles of Tile Installed</p>
        </div>
        <div class="text-center">
          <p class="text-5xl md:text-6xl font-black text-accent">30<span class="text-3xl">%</span></p>
          <p class="text-white/70 mt-2 font-medium">Avg. Yield Increase</p>
        </div>
        <div class="text-center">
          <p class="text-5xl md:text-6xl font-black text-accent">100<span class="text-3xl">%</span></p>
          <p class="text-white/70 mt-2 font-medium">Satisfaction Rate</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ TESTIMONIALS ═══════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-14">
        <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">Testimonials</p>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900">What Farmers Are Saying</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-surface rounded-2xl p-8 relative">
          <svg class="w-10 h-10 text-accent/30 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="text-gray-700 leading-relaxed mb-6">"We had 40 acres that were underwater every spring. Deep Roots put tile in last fall, and this spring we planted the whole quarter on time. Best money I've spent on the farm."</p>
          <div class="border-t border-surface-dark pt-4">
            <p class="font-bold text-gray-900">Mark T.</p>
            <p class="text-sm text-gray-500">Cass County, ND</p>
          </div>
        </div>
        <!-- Testimonial 2 -->
        <div class="bg-surface rounded-2xl p-8 relative">
          <svg class="w-10 h-10 text-accent/30 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="text-gray-700 leading-relaxed mb-6">"Professional from start to finish. They surveyed the field, showed me exactly where the tile would go, and had it done in three days. Our yields are up 20% on those acres."</p>
          <div class="border-t border-surface-dark pt-4">
            <p class="font-bold text-gray-900">Sarah & Jim L.</p>
            <p class="text-sm text-gray-500">Richland County, ND</p>
          </div>
        </div>
        <!-- Testimonial 3 -->
        <div class="bg-surface rounded-2xl p-8 relative">
          <svg class="w-10 h-10 text-accent/30 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="text-gray-700 leading-relaxed mb-6">"I wish I'd done this ten years ago. The GPS precision is impressive — every line is exactly where it should be. These guys know North Dakota ground."</p>
          <div class="border-t border-surface-dark pt-4">
            <p class="font-bold text-gray-900">Dave K.</p>
            <p class="text-sm text-gray-500">Traill County, ND</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA ═══════════ -->
  <section class="relative py-24 overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=1920&q=80"
      alt="Expansive farmland at golden hour"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-primary-dark/85"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-black text-white mb-4">Every Wet Season Is Costing You</h2>
      <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto">The ROI on drain tile is one of the best investments you can make in your operation. Let's look at your fields and put together a plan.</p>
      <a href="/contact" class="inline-block bg-accent hover:bg-accent-light text-primary-dark px-10 py-4 rounded-lg font-bold text-lg transition-colors shadow-xl">Get Your Free Estimate →</a>
    </div>
  </section>

</Layout>
)}
