---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative bg-primary-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/95 to-primary/80"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
      <div class="max-w-2xl">
        <p class="text-accent font-semibold text-sm tracking-wider uppercase mb-4">
          North Dakota's Drainage Experts
        </p>
        <h1 class="text-4xl md:text-6xl font-black text-white leading-tight">
          Protect Your Property From the Ground Up
        </h1>
        <p class="mt-6 text-lg text-white/80 leading-relaxed max-w-lg">
          Professional drain tile installation and waterproofing solutions 
          that keep your basement dry and your foundation strong.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="bg-accent hover:bg-accent-light text-primary-dark px-8 py-3.5 rounded-lg font-bold text-center transition-colors"
          >
            Get a Free Estimate
          </a>
          <a
            href="/services"
            class="border-2 border-white/30 hover:border-white/60 text-white px-8 py-3.5 rounded-lg font-bold text-center transition-colors"
          >
            Our Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-surface py-8 border-b border-surface-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl font-black text-primary">100%</p>
          <p class="text-sm text-earth font-medium mt-1">Satisfaction Guaranteed</p>
        </div>
        <div>
          <p class="text-3xl font-black text-primary">24hr</p>
          <p class="text-sm text-earth font-medium mt-1">Quote Turnaround</p>
        </div>
        <div>
          <p class="text-3xl font-black text-primary">Licensed</p>
          <p class="text-sm text-earth font-medium mt-1">& Fully Insured</p>
        </div>
        <div>
          <p class="text-3xl font-black text-primary">Local</p>
          <p class="text-sm text-earth font-medium mt-1">North Dakota Owned</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-accent font-semibold text-sm tracking-wider uppercase mb-2">What We Do</p>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900">Our Services</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-surface rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5">
            <span class="text-2xl">🏠</span>
          </div>
          <h3 class="text-xl font-bold mb-3">Exterior Drain Tile</h3>
          <p class="text-gray-600 leading-relaxed">
            Complete exterior drainage systems that divert water away from your foundation before it becomes a problem.
          </p>
        </div>

        <div class="bg-surface rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5">
            <span class="text-2xl">🔧</span>
          </div>
          <h3 class="text-xl font-bold mb-3">Interior Drain Tile</h3>
          <p class="text-gray-600 leading-relaxed">
            Interior drainage solutions with sump pump systems to manage water that enters your basement.
          </p>
        </div>

        <div class="bg-surface rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5">
            <span class="text-2xl">🛡️</span>
          </div>
          <h3 class="text-xl font-bold mb-3">Waterproofing</h3>
          <p class="text-gray-600 leading-relaxed">
            Foundation waterproofing and moisture barriers that protect your home for decades to come.
          </p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/services" class="text-primary font-bold hover:text-primary-light transition-colors">
          View All Services →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        Water Problems Don't Fix Themselves
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">
        Every day you wait, water is working against your foundation. 
        Get a free, no-obligation estimate and find out exactly what your property needs.
      </p>
      <a
        href="/contact"
        class="inline-block bg-accent hover:bg-accent-light text-primary-dark px-8 py-4 rounded-lg font-bold text-lg transition-colors"
      >
        Schedule Your Free Estimate
      </a>
    </div>
  </section>
</Layout>
