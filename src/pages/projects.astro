---
import Layout from '../layouts/Layout.astro'
import ProjectCard from '../storyblok/ProjectCard.astro'

const token = import.meta.env.STORYBLOK_TOKEN || 'KAaKAIFtzAtyOal659brwAtt'
const version = import.meta.env.DEV ? 'draft' : 'published'
const cv = Date.now()

let projects: any[] = []
try {
  const url = `https://api.storyblok.com/v2/cdn/stories?starts_with=projects/&is_startpage=false&version=${version}&token=${token}&cv=${cv}`
  const res = await fetch(url)
  const json = await res.json()
  projects = json.stories || []
  console.log(`[projects] Fetched ${projects.length} projects from Storyblok (status: ${res.status})`)
} catch (e: any) {
  console.error('[projects] Failed to fetch:', e.message)
}
---

<Layout title="Our Projects" description="See our agricultural drain tile projects across North Dakota.">
  <section class="relative py-28 md:py-36 overflow-hidden">
    <img src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=1400&q=80" alt="Expansive agricultural landscape" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/70 via-primary-dark/50 to-primary-dark/30"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">Our Work</p>
      <h1 class="text-4xl md:text-5xl font-black text-white">Our Projects</h1>
      <p class="mt-4 text-white/80 text-lg">Real fields. Real results.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {projects.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map((story: any) => (
            <ProjectCard blok={story.content} slug={story.slug} />
          ))}
        </div>
      ) : (
        <div class="text-center">
          <p class="text-gray-500">Projects coming soon. Check back for photos and details of our completed work.</p>
        </div>
      )}
    </div>
  </section>
</Layout>
