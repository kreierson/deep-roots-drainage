---
import Layout from '../../layouts/Layout.astro'
import Project from '../../storyblok/Project.astro'

export async function getStaticPaths() {
  const token = import.meta.env.STORYBLOK_TOKEN || 'KAaKAIFtzAtyOal659brwAtt'
  const cv = Date.now()
  try {
    const url = `https://api.storyblok.com/v2/cdn/stories?starts_with=projects/&is_startpage=false&version=published&token=${token}&cv=${cv}`
    const res = await fetch(url)
    const json = await res.json()
    console.log(`[projects/slug] Found ${json.stories?.length || 0} projects for static paths`)
    return (json.stories || []).map((story: any) => ({
      params: { slug: story.slug },
      props: { story },
    }))
  } catch (e: any) {
    console.error('[projects/slug] Failed:', e.message)
    return []
  }
}

const { story } = Astro.props
---

<Layout title={story.content.title || story.name} description={story.content.summary || undefined}>
  <Project blok={story.content} />
</Layout>
