---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Services" description="Professional drain tile, waterproofing, and drainage services in North Dakota.">
  <section class="bg-primary-dark py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-accent font-semibold text-sm tracking-wider uppercase mb-2">What We Offer</p>
      <h1 class="text-4xl md:text-5xl font-black text-white">Our Services</h1>
      <p class="mt-4 text-white/70 text-lg max-w-2xl">
        From new construction to existing homes, we provide complete drainage solutions tailored to North Dakota's unique soil and climate challenges.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
      <!-- Service 1 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-black text-gray-900 mb-4">Exterior Drain Tile</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            The most effective way to keep water out of your basement. We excavate around your foundation and install a perforated pipe system that collects and redirects groundwater before it reaches your walls.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Full foundation excavation</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> High-quality perforated pipe</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Gravel drainage bed</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Proper grading & backfill</li>
          </ul>
        </div>
        <div class="bg-surface rounded-2xl h-64 flex items-center justify-center text-earth">
          [Project Photo]
        </div>
      </div>

      <!-- Service 2 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1 bg-surface rounded-2xl h-64 flex items-center justify-center text-earth">
          [Project Photo]
        </div>
        <div class="order-1 md:order-2">
          <h2 class="text-3xl font-black text-gray-900 mb-4">Interior Drain Tile</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            When exterior work isn't practical, interior drain tile systems capture water inside your basement and route it to a sump pump for removal. Minimal disruption to your landscaping.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Interior perimeter channel</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Sump pump installation</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Battery backup options</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Vapor barrier systems</li>
          </ul>
        </div>
      </div>

      <!-- Service 3 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-black text-gray-900 mb-4">Foundation Waterproofing</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Multi-layer waterproofing membranes applied to your foundation walls create an impenetrable barrier against moisture. Combined with drain tile, it's the gold standard in water protection.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Waterproof membrane application</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Dimple board protection</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Crack repair & sealing</li>
            <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> Long-term warranty</li>
          </ul>
        </div>
        <div class="bg-surface rounded-2xl h-64 flex items-center justify-center text-earth">
          [Project Photo]
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-surface py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-black text-gray-900 mb-4">Not Sure What You Need?</h2>
      <p class="text-gray-600 text-lg mb-8">
        We'll assess your property and recommend the right solution. No pressure, no obligation.
      </p>
      <a href="/contact" class="inline-block bg-primary hover:bg-primary-light text-white px-8 py-4 rounded-lg font-bold text-lg transition-colors">
        Get a Free Assessment
      </a>
    </div>
  </section>
</Layout>
