---
import Layout from '../layouts/Layout.astro'
import { getEntry } from 'astro:content'

const page = await getEntry('pages', 'services')
const { Content, data } = page
---
<Layout title={data.seo_title || data.title} description={data.seo_description}>
  {data.hero && (
    <section class="relative py-28 md:py-36 overflow-hidden">
      <img src={data.hero.image} alt={data.hero.image_alt} class="absolute inset-0 w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/70 via-primary-dark/50 to-primary-dark/30"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{data.hero.eyebrow}</p>
        <h1 class="text-4xl md:text-5xl font-black text-white">{data.hero.title}</h1>
        <p class="mt-4 text-white/80 text-lg max-w-2xl">{data.hero.description}</p>
      </div>
    </section>
  )}

  {data.services && (
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
        {data.services.map((service, index) => (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div class={index % 2 === 1 ? "order-2 md:order-1" : ""}>
              <h2 class="text-3xl font-black text-gray-900 mb-4">{service.title}</h2>
              <p class="text-gray-600 leading-relaxed mb-4">{service.description}</p>
              {service.features && (
                <ul class="space-y-2 text-gray-600">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-2"><span class="text-primary font-bold">✓</span> {feature}</li>
                  ))}
                </ul>
              )}
            </div>
            <div class={`bg-surface rounded-2xl h-64 flex items-center justify-center text-earth ${index % 2 === 1 ? "order-1 md:order-2" : ""}`}>
              {service.image ? (
                <img src={service.image} alt={service.image_alt} class="w-full h-full object-cover rounded-2xl" />
              ) : (
                `[${service.title} Photo]`
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {data.cta && (
    <section class="bg-surface py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-black text-gray-900 mb-4">{data.cta.title}</h2>
        <p class="text-gray-600 text-lg mb-8">{data.cta.description}</p>
        <a href={data.cta.button_url} class="inline-block bg-primary hover:bg-primary-light text-white px-8 py-4 rounded-lg font-bold text-lg transition-colors">{data.cta.button_text}</a>
      </div>
    </section>
  )}
</Layout>
