---
import Layout from '../layouts/Layout.astro'
import { getCollection, getEntry } from 'astro:content'

const page = await getEntry('pages', 'team')
const { data } = page
const { Content } = await page.render()

const allMembers = await getCollection('team', ({ data }) => data.active !== false)
const teamMembers = await Promise.all(
  allMembers
    .sort((a, b) => {
      if (a.data.sort_order !== b.data.sort_order) return a.data.sort_order - b.data.sort_order
      return a.data.name.localeCompare(b.data.name)
    })
    .map(async (member) => {
      const rendered = await member.render()
      return { ...member, Content: rendered.Content }
    })
)
---
<Layout title={data.seo_title || data.title} description={data.seo_description}>
  {data.hero && (
    <section class="relative py-28 md:py-36 overflow-hidden">
      <img src={data.hero.image} alt={data.hero.image_alt} class="absolute inset-0 w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/70 via-primary-dark/50 to-primary-dark/30"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{data.hero.eyebrow}</p>
        <h1 class="text-4xl md:text-5xl font-black text-white">{data.hero.title}</h1>
        <p class="mt-4 text-white/80 text-lg max-w-2xl" set:html={data.hero.description}></p>
      </div>
    </section>
  )}

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
      </div>

      {teamMembers.length > 0 ? (
        <div class="mt-16 space-y-20">
          {teamMembers.map((member, index) => (
            <article class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
              <div class={index % 2 === 1 ? 'md:order-2' : ''}>
                <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{member.data.role}</p>
                <h2 class="text-3xl font-black text-gray-900 mb-4">{member.data.name}</h2>
                <p class="text-lg text-gray-600 leading-relaxed mb-6">{member.data.summary}</p>
                <div class="prose prose-lg max-w-none text-gray-700">
                  <member.Content />
                </div>
              </div>
              <div class={index % 2 === 1 ? 'md:order-1' : ''}>
                {member.data.image ? (
                  <img
                    src={member.data.image}
                    alt={member.data.image_alt || member.data.name}
                    class="w-full h-[420px] rounded-2xl object-cover shadow-xl"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-[420px] rounded-2xl bg-surface flex items-center justify-center text-earth font-semibold">
                    Photo Coming Soon
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="mt-16 rounded-2xl bg-surface p-10 text-center">
          <h2 class="text-2xl font-black text-gray-900">Team Profiles Coming Soon...</h2>
        </div>
      )}
    </div>
  </section>

  {data.cta && (
    <section class="bg-surface py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-black text-gray-900 mb-4">{data.cta.title}</h2>
        <p class="text-gray-600 text-lg mb-8">{data.cta.description}</p>
        <a href={data.cta.button_url} class="inline-block bg-primary hover:bg-primary-light text-white px-8 py-4 rounded-lg font-bold text-lg transition-colors">{data.cta.button_text}</a>
      </div>
    </section>
  )}
</Layout>
