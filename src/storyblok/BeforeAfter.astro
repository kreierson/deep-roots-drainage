---
import { storyblokEditable } from '@storyblok/astro'
const { blok } = Astro.props
---
<section class="py-24 bg-white" {...storyblokEditable(blok)}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-14">
      {blok.tagline && <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{blok.tagline}</p>}
      {blok.headline && <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight">{blok.headline}</h2>}
      {blok.subtitle && <p class="mt-4 text-gray-600 text-lg">{blok.subtitle}</p>}
    </div>
    <div class="grid md:grid-cols-2 gap-3">
      <div class="relative rounded-2xl overflow-hidden group">
        {blok.before_image?.filename && (
          <img src={blok.before_image.filename} alt={blok.before_image.alt || ''} class="w-full h-72 md:h-96 object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-red-900/80 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6">
          <span class="inline-block bg-red-600 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">{blok.before_label || 'Before'}</span>
          <p class="text-white font-bold text-xl">{blok.before_title}</p>
          <p class="text-white/70 text-sm mt-1">{blok.before_description}</p>
        </div>
      </div>
      <div class="relative rounded-2xl overflow-hidden group">
        {blok.after_image?.filename && (
          <img src={blok.after_image.filename} alt={blok.after_image.alt || ''} class="w-full h-72 md:h-96 object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/80 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6">
          <span class="inline-block bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">{blok.after_label || 'After'}</span>
          <p class="text-white font-bold text-xl">{blok.after_title}</p>
          <p class="text-white/70 text-sm mt-1">{blok.after_description}</p>
        </div>
      </div>
    </div>
  </div>
</section>
