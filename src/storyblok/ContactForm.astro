---
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
---

<section class="py-20" {...storyblokEditable(blok)}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
      <div class="lg:col-span-3">
        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Name *</label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                placeholder="Your name" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">Phone *</label>
              <input type="tel" id="phone" name="phone" required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                placeholder="(701) 555-0123" />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
            <input type="email" id="email" name="email"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
              placeholder="you@email.com" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="location" class="block text-sm font-semibold text-gray-700 mb-1">County / Area</label>
              <input type="text" id="location" name="location"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                placeholder="e.g. Cass County" />
            </div>
            <div>
              <label for="acres" class="block text-sm font-semibold text-gray-700 mb-1">Approx. Acres</label>
              <input type="text" id="acres" name="acres"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                placeholder="e.g. 160, 320" />
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">Tell Us About Your Project</label>
            <textarea id="message" name="message" rows="4"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition resize-y"
              placeholder="Describe your drainage issues — wet spots, ponding, crops, etc."></textarea>
          </div>
          <button type="submit"
            class="w-full bg-primary hover:bg-primary-light text-white py-4 rounded-lg font-bold text-lg transition-colors">
            {blok.button_text || 'Request Free Estimate'}
          </button>
        </form>
      </div>

      <div class="lg:col-span-2 space-y-8">
        <div class="bg-surface rounded-2xl p-8">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Contact Info</h3>
          <ul class="space-y-4 text-gray-600">
            {blok.phone && (
              <li class="flex items-start gap-3">
                <span class="text-xl">📞</span>
                <div>
                  <p class="font-semibold text-gray-900">{blok.phone}</p>
                  <p class="text-sm">Call or text</p>
                </div>
              </li>
            )}
            {blok.email && (
              <li class="flex items-start gap-3">
                <span class="text-xl">✉️</span>
                <div>
                  <p class="font-semibold text-gray-900">{blok.email}</p>
                  <p class="text-sm">We reply within 24 hours</p>
                </div>
              </li>
            )}
            {blok.location && (
              <li class="flex items-start gap-3">
                <span class="text-xl">📍</span>
                <div>
                  <p class="font-semibold text-gray-900">{blok.location}</p>
                </div>
              </li>
            )}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
