---
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
const bgClass = blok.style === 'light' ? 'bg-surface' : 'bg-primary'
const textClass = blok.style === 'light' ? 'text-gray-900' : 'text-white'
const subClass = blok.style === 'light' ? 'text-gray-600' : 'text-white/80'
---

<section class:list={['py-20', bgClass]} {...storyblokEditable(blok)}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class:list={['text-3xl md:text-4xl font-black mb-4', textClass]}>
      {blok.headline}
    </h2>
    {blok.subtitle && (
      <p class:list={['text-lg mb-8 max-w-2xl mx-auto', subClass]}>
        {blok.subtitle}
      </p>
    )}
    {blok.button_text && (
      <a
        href={blok.button_link?.cached_url || '/contact'}
        class:list={[
          'inline-block px-8 py-4 rounded-lg font-bold text-lg transition-colors',
          blok.style === 'light'
            ? 'bg-primary hover:bg-primary-light text-white'
            : 'bg-accent hover:bg-accent-light text-primary-dark',
        ]}
      >
        {blok.button_text}
      </a>
    )}
  </div>
</section>
