---
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
---

<section class="py-20" {...storyblokEditable(blok)}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {blok.headline && (
      <h2 class="text-3xl font-black text-gray-900 mb-8 text-center">{blok.headline}</h2>
    )}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {blok.images?.map((img: any) => (
        <div class="rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
          <img
            src={img.filename}
            alt={img.alt || ''}
            class="w-full h-64 object-cover"
          />
        </div>
      ))}
    </div>
  </div>
</section>
