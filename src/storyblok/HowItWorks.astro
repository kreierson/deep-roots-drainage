---
import { storyblokEditable } from '@storyblok/astro'
const { blok } = Astro.props
const steps = blok.steps || []
---
<section class="py-24 bg-surface" {...storyblokEditable(blok)}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        {blok.image?.filename && (
          <img src={blok.image.filename} alt={blok.image.alt || ''} class="rounded-2xl shadow-2xl w-full h-[500px] object-cover" loading="lazy" />
        )}
        <div class="absolute -bottom-6 -right-6 bg-accent text-primary-dark rounded-xl px-6 py-4 shadow-lg hidden md:block">
          <p class="text-3xl font-black">{steps.length}</p>
          <p class="text-sm font-bold">Simple Steps</p>
        </div>
      </div>
      <div>
        {blok.tagline && <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{blok.tagline}</p>}
        {blok.headline && <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-10">{blok.headline}</h2>}
        <div class="space-y-8">
          {steps.map((step: any) => (
            <div class="flex gap-5">
              <div class={`flex-shrink-0 w-12 h-12 rounded-full ${step.number === '✓' ? 'bg-accent text-primary-dark' : 'bg-primary text-white'} flex items-center justify-center font-black text-lg`}>{step.number}</div>
              <div>
                <h3 class="font-bold text-lg text-gray-900">{step.title}</h3>
                <p class="text-gray-600 mt-1">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
