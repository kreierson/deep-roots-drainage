---
import { storyblokEditable, renderRichText } from '@storyblok/astro'

const { blok } = Astro.props
const renderedDescription = blok.description ? renderRichText(blok.description) : ''
---

<article {...storyblokEditable(blok)}>
  <!-- Hero -->
  <section class="relative py-28 md:py-36 overflow-hidden">
    {blok.featured_image?.filename ? (
      <img
        src={blok.featured_image.filename + '/m/1400x0'}
        alt={blok.featured_image.alt || blok.title}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
    ) : (
      <div class="absolute inset-0 bg-primary-dark"></div>
    )}
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/90 via-primary-dark/75 to-primary-dark/40"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/projects" class="inline-flex items-center text-white/70 hover:text-white text-sm mb-6 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Projects
      </a>
      <h1 class="text-4xl md:text-5xl font-black text-white">{blok.title}</h1>
      <div class="mt-4 flex flex-wrap gap-4 text-white/80">
        {blok.location && (
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            {blok.location}
          </span>
        )}
        {blok.completion_date && (
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            {blok.completion_date}
          </span>
        )}
      </div>
    </div>
  </section>

  <!-- Description -->
  {renderedDescription && (
    <section class="py-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-lg prose-green">
        <Fragment set:html={renderedDescription} />
      </div>
    </section>
  )}

  <!-- Gallery -->
  {blok.gallery && blok.gallery.length > 0 && (
    <section class="pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold mb-8">Project Photos</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {blok.gallery.map((img: any) => (
            <div class="rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
              <img
                src={img.filename + '/m/800x600'}
                alt={img.alt || ''}
                class="w-full h-64 object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</article>
