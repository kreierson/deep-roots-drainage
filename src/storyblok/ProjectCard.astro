---
import { storyblokEditable } from '@storyblok/astro'

const { blok, slug } = Astro.props
---

<a
  href={`/projects/${slug}`}
  class="group block bg-white rounded-2xl overflow-hidden hover:shadow-lg transition-shadow border border-gray-100"
  {...storyblokEditable(blok)}
>
  <div class="aspect-[4/3] overflow-hidden">
    {blok.featured_image?.filename ? (
      <img
        src={blok.featured_image.filename + '/m/800x600'}
        alt={blok.featured_image.alt || blok.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-surface flex items-center justify-center text-earth">
        No image
      </div>
    )}
  </div>
  <div class="p-5">
    <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary transition-colors">{blok.title}</h3>
    {blok.summary && (
      <p class="mt-2 text-gray-600 text-sm line-clamp-2">{blok.summary}</p>
    )}
  </div>
</a>
