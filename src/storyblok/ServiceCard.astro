---
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
---

<div class="bg-white rounded-2xl p-8 hover:shadow-lg transition-shadow border border-gray-100" {...storyblokEditable(blok)}>
  {blok.image?.filename && (
    <div class="rounded-xl overflow-hidden mb-5 -mx-2 -mt-2">
      <img src={blok.image.filename} alt={blok.image.alt || blok.title} class="w-full h-48 object-cover" />
    </div>
  )}
  <h3 class="text-xl font-bold mb-3">{blok.title}</h3>
  <p class="text-gray-600 leading-relaxed">{blok.description}</p>
  {blok.features && (
    <ul class="mt-4 space-y-2 text-gray-600">
      {blok.features.split('\n').filter(Boolean).map((f: string) => (
        <li class="flex items-start gap-2">
          <span class="text-primary font-bold">✓</span> {f}
        </li>
      ))}
    </ul>
  )}
</div>
