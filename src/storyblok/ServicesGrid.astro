---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'

const { blok } = Astro.props
const cols = blok.columns || 3
---

<section
  class:list={['py-20', blok.background === 'light' ? 'bg-surface' : 'bg-white']}
  {...storyblokEditable(blok)}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {blok.tagline && (
      <p class="text-accent font-semibold text-sm tracking-wider uppercase mb-2 text-center">
        {blok.tagline}
      </p>
    )}
    {blok.headline && (
      <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4 text-center">
        {blok.headline}
      </h2>
    )}
    {blok.subtitle && (
      <p class="text-gray-600 text-lg mb-12 max-w-2xl mx-auto text-center">
        {blok.subtitle}
      </p>
    )}
    <div class:list={[
      'grid grid-cols-1 gap-8',
      cols === 2 ? 'md:grid-cols-2' : cols === 4 ? 'sm:grid-cols-2 md:grid-cols-4' : 'md:grid-cols-3',
    ]}>
      {blok.items?.map((item: any) => (
        <StoryblokComponent blok={item} />
      ))}
    </div>
  </div>
</section>
