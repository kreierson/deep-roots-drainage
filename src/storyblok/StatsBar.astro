---
import { storyblokEditable } from '@storyblok/astro'
const { blok } = Astro.props
const stats = blok.stats || []
---
<section class="relative py-24 bg-primary-dark overflow-hidden" {...storyblokEditable(blok)}>
  <div class="absolute inset-0 opacity-[0.07]">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
      <g fill="none" stroke="white" stroke-width="1.5">
        <ellipse cx="400" cy="300" rx="380" ry="260"/><ellipse cx="400" cy="300" rx="300" ry="200"/><ellipse cx="400" cy="300" rx="220" ry="140"/><ellipse cx="400" cy="300" rx="140" ry="80"/><ellipse cx="400" cy="300" rx="60" ry="30"/>
        <ellipse cx="200" cy="150" rx="160" ry="110"/><ellipse cx="200" cy="150" rx="80" ry="50"/>
        <ellipse cx="650" cy="450" rx="140" ry="100"/><ellipse cx="650" cy="450" rx="60" ry="40"/>
      </g>
    </svg>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      {blok.tagline && <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{blok.tagline}</p>}
      {blok.headline && <h2 class="text-3xl md:text-5xl font-black text-white">{blok.headline}</h2>}
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((s: any) => (
        <div class="text-center">
          <p class="text-5xl md:text-6xl font-black text-accent">{s.value}<span class="text-3xl">{s.suffix}</span></p>
          <p class="text-white/70 mt-2 font-medium">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
