---
import { storyblokEditable } from '@storyblok/astro'
const { blok } = Astro.props
const items = blok.items || []
---
<section class="py-24 bg-white" {...storyblokEditable(blok)}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-14">
      {blok.tagline && <p class="text-accent font-semibold text-sm tracking-[0.2em] uppercase mb-2">{blok.tagline}</p>}
      {blok.headline && <h2 class="text-3xl md:text-4xl font-black text-gray-900">{blok.headline}</h2>}
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {items.map((t: any) => (
        <div class="bg-surface rounded-2xl p-8 relative">
          <svg class="w-10 h-10 text-accent/30 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="text-gray-700 leading-relaxed mb-6">"{t.quote}"</p>
          <div class="border-t border-surface-dark pt-4">
            <p class="font-bold text-gray-900">{t.name}</p>
            {t.location && <p class="text-sm text-gray-500">{t.location}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
